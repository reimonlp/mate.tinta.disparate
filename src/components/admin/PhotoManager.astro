---
import AdminModal from './AdminModal.astro';
const { photos } = Astro.props;
---

<section id="fotos" class="tab-content">
  <div class="section-header">
    <h2>Galería de Fotos</h2>
    <button class="btn-primary" id="btn-add-photo">+ Subir Foto</button>
  </div>
  <div class="photos-grid" id="photos-container">
    {photos.map(photo => (
      <div class="photo-card" data-photo-id={photo}>
        <img src={encodeURI(`/photos/${photo}`)} alt={photo} loading="lazy" />
        <div class="photo-actions">
          <button class="btn-danger btn-sm" onclick={`deleteItem('photos', '${photo}')`}>Eliminar</button>
        </div>
      </div>
    ))}
    {photos.length === 0 && <p id="no-photos">No hay fotos subidas.</p>}
  </div>
</section>

<AdminModal id="modal-photo" title="Subir Foto">
  <div class="form-group">
    <label>Elegir Imagen (JPG/PNG/WEBP)</label>
    <input type="file" id="photo-input" class="form-control" accept="image/*">
  </div>
  <button class="btn-primary" id="submit-photo">Subir Imagen</button>
</AdminModal>

<script is:inline>
  const btnAddPhoto = document.getElementById('btn-add-photo');
  const modalPhoto = document.getElementById('modal-photo');

  btnAddPhoto?.addEventListener('click', () => {
    document.getElementById('photo-input').value = '';
    modalPhoto.style.display = 'block';
  });

  document.getElementById('submit-photo')?.addEventListener('click', async () => {
    const input = document.getElementById('photo-input');
    if (!input.files || input.files.length === 0) return window.showToast('Seleccioná una imagen', true);

    const file = input.files[0];
    const reader = new FileReader();
    reader.onload = async (e) => {
      const base64 = e.target.result.split(',')[1];
      window.showToast('Subiendo y optimizando...');
      
      const response = await fetch('/api/photos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          name: file.name,
          type: file.type,
          data: base64
        })
      });

      if (response.ok) {
        window.showToast('Foto subida con éxito');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        window.showToast('Error al subir', true);
      }
    };
    reader.readAsDataURL(file);
  });
</script>
