---
interface Props {
  label: string;
  count: number;
  icon: string;
  color: string;
}

const { label, count, icon, color } = Astro.props;
---

<div class="stat-card">
  <div class="stat-icon" style={`color: ${color}; background-color: ${color}15;`} set:html={icon}></div>
  <div class="stat-info">
    <h3>{count}</h3>
    <p>{label}</p>
  </div>
</div>

<style>
  /* Styles moved to admin.css */
</style>
