---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div id={id} class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2>{title}</h2>
      <button class="close-modal" onclick={`document.getElementById('${id}').style.display='none'`}>&times;</button>
    </div>
    <div class="modal-body">
      <slot />
    </div>
  </div>
</div>

<style>
  /* Styles moved to admin.css */
</style>
